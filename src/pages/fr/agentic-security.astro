---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import siteContent from '../../content/site.fr.json';
import agenticContent from '../../content/agentic-security.fr.json';

const lang = 'fr';
const pageTitle = agenticContent.meta.title;
const pageDescription = agenticContent.meta.description;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Header lang={lang} content={siteContent} />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden py-16 md:py-20 lg:py-28 bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900">
      <div class="absolute inset-0 opacity-5">
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px]" viewBox="0 0 200 200" fill="none">
          <path d="M100 10 L180 50 L180 110 C180 150 145 185 100 195 C55 185 20 150 20 110 L20 50 Z" stroke="currentColor" stroke-width="1" class="text-primary-400"/>
        </svg>
      </div>
      <div class="container-custom relative">
        <div class="mx-auto max-w-4xl text-center">
          <h1 class="mb-6 text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight">
            {agenticContent.hero.title}
          </h1>
          <p class="mb-6 text-xl md:text-2xl text-secondary-300 max-w-3xl mx-auto">
            {agenticContent.hero.subtitle}
          </p>
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed text-center">
            {agenticContent.intro}
          </p>
        </div>
      </div>
    </section>

    <!-- Passerelle Proxy MCP -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-6 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.mcp_gateway.title}
          </h2>
          <div class="rounded-2xl border border-primary-200 dark:border-primary-800 bg-primary-50 dark:bg-primary-900/20 p-8 md:p-10 mb-8">
            <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
              {agenticContent.mcp_gateway.description}
            </p>
          </div>
          <ul class="space-y-3">
            {agenticContent.mcp_gateway.features.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Interception des Appels d'Outils -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.tool_interception.title}
          </h2>
          <p class="mb-10 text-center text-lg text-secondary-600 dark:text-secondary-300">
            {agenticContent.tool_interception.description}
          </p>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
            {agenticContent.tool_interception.policies.map((policy) => (
              <div class="p-5 rounded-2xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <p class="font-bold text-primary-600 dark:text-primary-400 mb-1">{policy.name}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{policy.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Détection d'Attaques par Chaîne d'Actions -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.chain_tracking.title}
          </h2>
          <p class="mb-10 text-center text-lg text-secondary-600 dark:text-secondary-300">
            {agenticContent.chain_tracking.description}
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {agenticContent.chain_tracking.patterns.map((pattern) => (
              <div class="flex items-start gap-4 p-5 rounded-2xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <svg class="mt-0.5 h-6 w-6 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <div>
                  <p class="font-semibold text-secondary-900 dark:text-white">{pattern.name}</p>
                  <p class="text-sm text-secondary-600 dark:text-secondary-400">{pattern.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Sécurité d'Orchestration Multi-Agents -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-8 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.multi_agent.title}
          </h2>
          <ul class="space-y-3">
            {agenticContent.multi_agent.items.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Benchmarks -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-2 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.benchmarks.title}
          </h2>
          <p class="mb-10 text-center text-secondary-500 dark:text-secondary-400">{agenticContent.benchmarks.subtitle}</p>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
            {agenticContent.benchmarks.items.map((item) => (
              <div class="text-center p-5 rounded-2xl bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800">
                <p class="text-2xl md:text-3xl font-bold text-primary-600 dark:text-primary-400 mb-1">{item.value}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Validation d'Integrite Zero-Trust -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-6 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.instruction_integrity.title}
          </h2>
          <div class="rounded-2xl border border-primary-200 dark:border-primary-800 bg-primary-50 dark:bg-primary-900/20 p-8 md:p-10 mb-8">
            <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
              {agenticContent.instruction_integrity.description}
            </p>
          </div>
          <ul class="space-y-3">
            {agenticContent.instruction_integrity.features.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Prevention des Mouvements Lateraux -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-6 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.lateral_movement.title}
          </h2>
          <div class="rounded-2xl border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 p-8 md:p-10 mb-8">
            <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
              {agenticContent.lateral_movement.description}
            </p>
          </div>
          <ul class="space-y-3">
            {agenticContent.lateral_movement.features.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Execution en Bac a Sable OpenShell -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-6 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {agenticContent.sandbox_execution.title}
          </h2>
          <div class="rounded-2xl border border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-900/20 p-8 md:p-10 mb-8">
            <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
              {agenticContent.sandbox_execution.description}
            </p>
          </div>
          <ul class="space-y-3 mb-8">
            {agenticContent.sandbox_execution.features.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
          <div class="text-center">
            <a
              href={agenticContent.sandbox_execution.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Voir le template bac a sable sur GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gradient-to-br from-primary-600 to-primary-700 dark:from-primary-700 dark:to-primary-800">
      <div class="container-custom text-center">
        <h2 class="mb-4 text-2xl md:text-3xl font-bold text-white">
          Voyez les attaques d'agents bloquees en direct
        </h2>
        <p class="mb-8 text-lg text-primary-100 max-w-2xl mx-auto">
          Regardez ForceField intercepter les appels d'outils, bloquer l'exfiltration de donnees et stopper les attaques en chaine dans le Demo Lab.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://forcefield.datasciencetech.ca/demo-lab"
            class="btn inline-flex items-center gap-2 bg-white text-primary-700 hover:bg-primary-50 focus:ring-white text-lg px-8 py-4"
          >
            Essayer Demo Lab
          </a>
          <a
            href="https://forcefield.datasciencetech.ca/scan/start"
            class="btn inline-flex items-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 text-lg px-8 py-4"
          >
            Lancer un scan
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
