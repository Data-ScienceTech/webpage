---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import siteContent from '../../content/site.fr.json';
import productContent from '../../content/forcefield.fr.json';

const lang = 'fr';
const pageTitle = productContent.meta.title;
const pageDescription = productContent.meta.description;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Header lang={lang} content={siteContent} />

  <main>
    <!-- Hero: Compact headline + intro + metrics above the fold -->
    <section class="relative overflow-hidden bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900 pt-12 pb-10 md:pt-16 md:pb-12">
      <div class="absolute inset-0 opacity-5">
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px]" viewBox="0 0 200 200" fill="none">
          <path d="M100 10 L180 50 L180 110 C180 150 145 185 100 195 C55 185 20 150 20 110 L20 50 Z" stroke="currentColor" stroke-width="1" class="text-primary-400"/>
        </svg>
      </div>
      <div class="container-custom relative">
        <div class="mx-auto max-w-4xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary-400">{productContent.hero.subtitle}</p>
          <h1 class="mb-5 text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight">
            {productContent.hero.title}
          </h1>
          <p class="mb-6 text-lg text-secondary-300 leading-relaxed max-w-3xl">
            {productContent.intro}
          </p>
          <p class="mb-8 text-lg font-semibold text-primary-400">
            {productContent.intro_closing}
          </p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="rounded-xl bg-white/5 border border-white/10 p-4 text-center">
              <p class="text-2xl md:text-3xl font-bold text-primary-400">98,9 %</p>
              <p class="text-xs text-secondary-400 mt-1">Detection d'attaques</p>
            </div>
            <div class="rounded-xl bg-white/5 border border-white/10 p-4 text-center">
              <p class="text-2xl md:text-3xl font-bold text-primary-400">100 %</p>
              <p class="text-xs text-secondary-400 mt-1">Prevention des fuites</p>
            </div>
            <div class="rounded-xl bg-white/5 border border-white/10 p-4 text-center">
              <p class="text-2xl md:text-3xl font-bold text-primary-400">~ 1 ms</p>
              <p class="text-xs text-secondary-400 mt-1">Securite P99</p>
            </div>
            <div class="rounded-xl bg-white/5 border border-white/10 p-4 text-center">
              <p class="text-2xl md:text-3xl font-bold text-primary-400">1 650+</p>
              <p class="text-xs text-secondary-400 mt-1">Tests reussis</p>
            </div>
          </div>
          <a
            href={`/${lang}/inscription`}
            class="btn-accent inline-flex items-center gap-2 text-base px-6 py-3"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Commencer gratuitement
          </a>
        </div>
      </div>
    </section>

    <!-- Zero Trust par Defaut -->
    <section class="py-10 md:py-14 bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white">
            {productContent.mcp_onramp.title}
          </h2>
          <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
            {productContent.mcp_onramp.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Capacités principales — 3 cartes -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <h2 class="mb-12 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
          {productContent.capabilities.title}
        </h2>
        <div class="grid gap-8 md:grid-cols-3 max-w-5xl mx-auto">
          {productContent.capabilities.items.slice(0, 3).map((cap) => (
            <div class="rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-white dark:bg-secondary-800 p-8 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <h3 class="mb-4 text-xl font-bold text-secondary-900 dark:text-white">
                {cap.title}
              </h3>
              <ul class="space-y-3">
                {cap.items.map((item: string) => (
                  <li class="flex items-start gap-3 text-secondary-600 dark:text-secondary-300">
                    <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="grid gap-8 md:grid-cols-2 max-w-3xl mx-auto mt-8">
          {productContent.capabilities.items.slice(3, 5).map((cap) => (
            <div class="rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-white dark:bg-secondary-800 p-8 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <h3 class="mb-4 text-xl font-bold text-secondary-900 dark:text-white">
                {cap.title}
              </h3>
              <ul class="space-y-3">
                {cap.items.map((item: string) => (
                  <li class="flex items-start gap-3 text-secondary-600 dark:text-secondary-300">
                    <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pipeline de Sécurité en 10 Étapes -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-10 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {productContent.pipeline.title}
          </h2>
          <div class="space-y-3">
            {productContent.pipeline.steps.map((step) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white text-sm font-bold">
                  {step.number}
                </span>
                <div>
                  <span class="font-semibold text-secondary-900 dark:text-white">{step.name}</span>
                  <span class="text-secondary-500 dark:text-secondary-400 mx-2">&mdash;</span>
                  <span class="text-secondary-600 dark:text-secondary-300">{step.description}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Sécurité de l'IA Agentique -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-6 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {productContent.agentic_security.title}
          </h2>
          <div class="rounded-2xl border border-primary-200 dark:border-primary-800 bg-primary-50 dark:bg-primary-900/20 p-8 md:p-10 mb-8">
            <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed">
              {productContent.agentic_security.description}
            </p>
          </div>
          <ul class="grid gap-4 sm:grid-cols-2">
            {productContent.agentic_security.items.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Résultats des Benchmarks -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-10 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {productContent.benchmarks.title}
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-10">
            {productContent.benchmarks.core.map((item) => (
              <div class="text-center p-5 rounded-2xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <p class="text-2xl md:text-3xl font-bold text-primary-600 dark:text-primary-400 mb-1">{item.value}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{item.label}</p>
              </div>
            ))}
          </div>
          <h3 class="mb-6 text-xl font-bold text-secondary-900 dark:text-white text-center">
            {productContent.benchmarks.agentic_title}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {productContent.benchmarks.agentic.map((item) => (
              <div class="text-center p-5 rounded-2xl bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800">
                <p class="text-2xl md:text-3xl font-bold text-primary-600 dark:text-primary-400 mb-1">{item.value}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Ce que cela permet -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-8 text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center">
            {productContent.what_this_enables.title}
          </h2>
          <ul class="grid gap-4 sm:grid-cols-2">
            {productContent.what_this_enables.items.map((item: string) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-secondary-700 dark:text-secondary-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA Inscription -->
    <section class="section-padding bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900">
      <div class="container-custom text-center">
        <h2 class="mb-4 text-3xl font-bold text-white">
          Commencez avec Force Field
        </h2>
        <p class="mb-8 text-lg text-secondary-300 max-w-2xl mx-auto">
          Créez votre compte gratuit, obtenez une clé API et commencez à sécuriser vos systèmes IA en moins d'une minute.
        </p>
        <a
          href={`/${lang}/inscription`}
          class="btn inline-flex items-center gap-2 bg-white text-primary-700 hover:bg-primary-50 focus:ring-white text-lg px-8 py-4"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Créer un compte gratuit
        </a>
        <p class="mt-6 text-sm text-secondary-400">
          Gratuit pendant l'accès anticipé. Aucune carte de crédit requise.
        </p>
      </div>
    </section>

    <!-- Badges -->
    <section class="py-8 bg-secondary-50 dark:bg-secondary-900 border-t border-secondary-200 dark:border-secondary-700">
      <div class="container-custom">
        <div class="flex flex-wrap items-center justify-center gap-4">
          {productContent.footer.badges.map((badge: string) => (
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800 text-primary-700 dark:text-primary-300 text-sm font-medium">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              {badge}
            </span>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
