---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import siteContent from '../../content/site.en.json';

const lang = 'en';
const dashboardUrl = 'https://forcefield.datasciencetech.ca/signup';
---

<MainLayout
  title={`Get Started | ${siteContent.company}`}
  description="Create your ForceField account — enterprise-grade LLM security in under a minute."
  lang={lang}
>
  <Header lang={lang} content={siteContent} />
  
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-secondary-900 to-secondary-800 py-16">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-500/20 text-primary-400 text-sm font-medium mb-6">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Free During Early Access
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Get Started with ForceField</h1>
          <p class="text-xl text-secondary-300 mb-10">
            Create your account, get an API key, and start securing your AI systems in under a minute.
          </p>
          <a
            href={dashboardUrl}
            class="btn-primary inline-flex items-center gap-2 text-lg px-8 py-4"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Create Free Account
          </a>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="section-padding">
      <div class="container-custom">
        <h2 class="mb-12 text-3xl font-bold text-secondary-900 dark:text-white text-center">Up and running in 3 steps</h2>
        <div class="grid gap-8 md:grid-cols-3 max-w-4xl mx-auto">
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 text-xl font-bold mb-4">1</div>
            <h3 class="text-lg font-bold text-secondary-900 dark:text-white mb-2">Create your account</h3>
            <p class="text-secondary-600 dark:text-secondary-400 text-sm">Sign up with email or Google. No credit card required.</p>
          </div>
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 text-xl font-bold mb-4">2</div>
            <h3 class="text-lg font-bold text-secondary-900 dark:text-white mb-2">Get your API key</h3>
            <p class="text-secondary-600 dark:text-secondary-400 text-sm">Receive your API key instantly. Add it as the <code class="px-1 py-0.5 rounded bg-secondary-100 dark:bg-secondary-800 text-xs">X-API-Key</code> header.</p>
          </div>
          <div class="text-center">
            <div class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 text-xl font-bold mb-4">3</div>
            <h3 class="text-lg font-bold text-secondary-900 dark:text-white mb-2">Monitor your dashboard</h3>
            <p class="text-secondary-600 dark:text-secondary-400 text-sm">View threats, manage keys, and track usage in real time.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What You Get -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-3xl">
          <h2 class="mb-8 text-3xl font-bold text-secondary-900 dark:text-white text-center">Included in Early Access</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {[
              'Real-time threat detection (98.9% accuracy)',
              'Security dashboard with analytics',
              'API key management',
              'Prompt injection & jailbreak blocking',
              'PII leak prevention (18 entity types)',
              'Audit trail & compliance export',
              'Token budget controls',
              'Email & community support',
            ].map((item) => (
              <div class="flex items-start gap-3 p-4 rounded-xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <svg class="mt-0.5 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-secondary-700 dark:text-secondary-300">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-16 bg-gradient-to-br from-primary-600 to-primary-700 dark:from-primary-700 dark:to-primary-800">
      <div class="container-custom text-center">
        <p class="mb-2 text-2xl md:text-3xl font-bold text-white">Ready to secure your AI systems?</p>
        <p class="mb-8 text-primary-100">Free during Early Access. No credit card required.</p>
        <a
          href={dashboardUrl}
          class="btn inline-flex items-center gap-2 bg-white text-primary-700 hover:bg-primary-50 focus:ring-white text-lg px-8 py-4"
        >
          Create Free Account
        </a>
        <p class="mt-6 text-sm text-primary-200">
          Already have an account?
          <a href={dashboardUrl} class="text-white underline hover:text-primary-100">Sign in to your dashboard</a>
        </p>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>