---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import siteContent from '../../content/site.en.json';
import content from '../../content/python-sdk.en.json';

const lang = 'en';
---

<MainLayout
  title={content.meta.title}
  description={content.meta.description}
  lang={lang}
>
  <Header lang={lang} content={siteContent} />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900 pt-12 pb-10 md:pt-16 md:pb-12">
      <div class="absolute inset-0 opacity-5">
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px]" viewBox="0 0 200 200" fill="none">
          <rect x="30" y="30" width="140" height="140" rx="20" stroke="currentColor" stroke-width="1" class="text-primary-400"/>
          <path d="M70 80 L100 80 M70 100 L130 100 M70 120 L115 120" stroke="currentColor" stroke-width="2" class="text-primary-400" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="container-custom relative">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary-500/20 px-4 py-1.5 text-sm font-semibold text-primary-300">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            PyPI v0.3.0
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight mb-4">
            {content.hero.title}
          </h1>
          <p class="text-lg md:text-xl text-secondary-300 mb-6 max-w-2xl mx-auto">
            {content.hero.tagline}
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
            <div class="relative group">
              <div class="bg-secondary-800 border border-secondary-600 rounded-lg px-6 py-3 font-mono text-primary-300 text-lg select-all cursor-pointer">
                $ pip install forcefield
              </div>
              <div class="absolute -top-2 -right-2 bg-primary-500 text-white text-xs rounded-full px-2 py-0.5 font-semibold">copy</div>
            </div>
            <a href={content.cta.pypi_url} target="_blank" rel="noopener" class="btn-accent inline-flex items-center gap-2 text-base px-6 py-3">
              {content.cta.pypi}
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>

          <!-- Stats bar -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
            {content.stats.map((stat: any) => (
              <div class="bg-white/5 rounded-lg p-3 backdrop-blur-sm border border-white/10">
                <div class="text-2xl font-bold text-white">{stat.value}</div>
                <div class="text-xs text-secondary-400">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Install options -->
    <section class="bg-white dark:bg-secondary-900 py-12">
      <div class="container-custom">
        <div class="mx-auto max-w-3xl">
          <h2 class="text-2xl font-bold text-secondary-900 dark:text-white text-center mb-8">{content.install.title}</h2>
          <div class="space-y-3">
            {[
              { cmd: content.install.basic, label: content.install.basic_label, accent: false },
              { cmd: content.install.ml, label: content.install.ml_label, accent: true },
              { cmd: content.install.all, label: content.install.all_label, accent: false },
            ].map((row: any) => (
              <div class={`flex flex-col sm:flex-row items-start sm:items-center gap-3 rounded-lg p-4 ${row.accent ? 'bg-primary-50 dark:bg-primary-900/20 border-2 border-primary-200 dark:border-primary-700' : 'bg-secondary-50 dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700'}`}>
                <code class="font-mono text-sm sm:text-base text-secondary-900 dark:text-white flex-shrink-0">$ {row.cmd}</code>
                <span class="text-sm text-secondary-500 dark:text-secondary-400 sm:ml-auto">{row.label}</span>
                {row.accent && <span class="text-xs bg-primary-500 text-white rounded-full px-2 py-0.5 font-semibold">recommended</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Quickstart code -->
    <section class="bg-secondary-50 dark:bg-secondary-800 py-12">
      <div class="container-custom">
        <div class="mx-auto max-w-3xl">
          <h2 class="text-2xl font-bold text-secondary-900 dark:text-white text-center mb-8">{content.quickstart.title}</h2>
          <div class="bg-secondary-900 dark:bg-secondary-950 rounded-xl overflow-hidden shadow-xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-secondary-800 dark:bg-secondary-900 border-b border-secondary-700">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-2 text-xs text-secondary-400 font-mono">app.py</span>
            </div>
            <pre class="p-6 text-sm md:text-base overflow-x-auto"><code class="text-green-400 font-mono">{content.quickstart.code}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Features grid -->
    <section class="bg-white dark:bg-secondary-900 py-16">
      <div class="container-custom">
        <h2 class="text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center mb-12">{content.features.title}</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
          {content.features.items.map((feature: any) => (
            <div class="rounded-xl border border-secondary-200 dark:border-secondary-700 p-6 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <div class="mb-3 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <h3 class="text-base font-semibold text-secondary-900 dark:text-white mb-2">{feature.title}</h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Integrations -->
    <section class="bg-secondary-50 dark:bg-secondary-800 py-16">
      <div class="container-custom">
        <h2 class="text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center mb-12">{content.integrations.title}</h2>
        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {content.integrations.items.map((integration: any) => (
            <div class="bg-white dark:bg-secondary-900 rounded-xl border border-secondary-200 dark:border-secondary-700 overflow-hidden">
              <div class="bg-secondary-900 dark:bg-secondary-950 px-4 py-3 border-b border-secondary-700">
                <span class="text-sm font-semibold text-primary-400">{integration.name}</span>
              </div>
              <pre class="px-4 py-3 text-xs overflow-x-auto bg-secondary-900 dark:bg-secondary-950"><code class="text-green-400 font-mono">{integration.code}</code></pre>
              <div class="p-4">
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{integration.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CLI -->
    <section class="bg-white dark:bg-secondary-900 py-16">
      <div class="container-custom">
        <h2 class="text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center mb-8">{content.cli.title}</h2>
        <div class="mx-auto max-w-3xl space-y-3">
          {content.cli.commands.map((cmd: any) => (
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 bg-secondary-50 dark:bg-secondary-800 rounded-lg p-4 border border-secondary-200 dark:border-secondary-700">
              <code class="font-mono text-sm text-primary-600 dark:text-primary-400">$ {cmd.cmd}</code>
              <span class="text-sm text-secondary-500 dark:text-secondary-400 sm:ml-auto">{cmd.description}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SDK vs Gateway comparison -->
    <section class="bg-secondary-50 dark:bg-secondary-800 py-16">
      <div class="container-custom">
        <h2 class="text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center mb-8">{content.comparison.title}</h2>
        <div class="mx-auto max-w-4xl overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-secondary-300 dark:border-secondary-600">
                {content.comparison.headers.map((h: string) => (
                  <th class="px-4 py-3 text-left font-semibold text-secondary-900 dark:text-white">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {content.comparison.rows.map((row: string[]) => (
                <tr class="border-b border-secondary-200 dark:border-secondary-700">
                  <td class="px-4 py-3 font-medium text-secondary-900 dark:text-white">{row[0]}</td>
                  <td class="px-4 py-3 text-secondary-600 dark:text-secondary-400">{row[1]}</td>
                  <td class="px-4 py-3 text-secondary-600 dark:text-secondary-400">{row[2]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Optional extras -->
    <section class="bg-white dark:bg-secondary-900 py-12">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-secondary-900 dark:text-white text-center mb-8">{content.extras.title}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
          {content.extras.items.map((extra: any) => (
            <div class="flex items-start gap-3 rounded-lg bg-secondary-50 dark:bg-secondary-800 p-4 border border-secondary-200 dark:border-secondary-700">
              <code class="text-xs font-mono bg-secondary-200 dark:bg-secondary-700 text-secondary-800 dark:text-secondary-200 rounded px-2 py-1 flex-shrink-0 mt-0.5">{extra.name}</code>
              <span class="text-sm text-secondary-600 dark:text-secondary-400">{extra.description}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gradient-to-r from-primary-600 to-primary-800 py-16">
      <div class="container-custom text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Secure your AI app today</h2>
        <p class="text-lg text-primary-100 mb-8 max-w-2xl mx-auto">
          Install ForceField in seconds. No API keys required. Start detecting prompt injection, PII leaks, and LLM attacks immediately.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={content.cta.pypi_url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-primary-700 font-semibold px-8 py-3 rounded-lg hover:bg-primary-50 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            {content.cta.pypi}
          </a>
          <a href={content.cta.github_url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/10 text-white font-semibold px-8 py-3 rounded-lg hover:bg-white/20 transition-colors border border-white/30">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            {content.cta.github}
          </a>
          <a href={content.cta.gateway_url} class="inline-flex items-center gap-2 text-white/80 font-medium hover:text-white transition-colors">
            {content.cta.gateway}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
