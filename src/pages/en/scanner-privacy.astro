---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import siteContent from '../../content/site.en.json';

const lang = 'en';
---

<MainLayout
  title={`Scanner Privacy Addendum | ${siteContent.company}`}
  description="Scanner Privacy Addendum — how the ForceField Scanner processes and handles your data."
  lang={lang}
>
  <Header lang={lang} content={siteContent} />
  
  <main>
    <section class="bg-gradient-to-br from-secondary-900 to-secondary-800 py-16">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-500/20 text-primary-400 text-sm font-medium mb-6">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Privacy
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Scanner Privacy Addendum</h1>
          <p class="text-xl text-secondary-300">
            How the ForceField Scanner processes and handles your data.
          </p>
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          
          <div class="mb-8 p-6 rounded-xl bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500 text-white flex-shrink-0">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">
                  <strong class="text-secondary-900 dark:text-white">Last Updated:</strong> March 15, 2026<br />
                  <strong class="text-secondary-900 dark:text-white">Legal Entity:</strong> 9558-6616 Qu&eacute;bec Inc.<br />
                  <strong class="text-secondary-900 dark:text-white">Version fran&ccedil;aise :</strong> <a href="/fr/confidentialite-scanner" class="text-primary-600 dark:text-primary-400 hover:underline">Addendum de confidentialit&eacute; du Scanner</a><br />
                  <strong class="text-secondary-900 dark:text-white">Parent Policy:</strong> <a href="/en/privacy" class="text-primary-600 dark:text-primary-400 hover:underline">ForceField Privacy Policy</a>
                </p>
              </div>
            </div>
          </div>

          <div class="prose prose-lg dark:prose-invert max-w-none">

            <h2 class="mt-8 text-2xl font-bold text-secondary-900 dark:text-white">Data Processed by the Scanner</h2>
            <p class="text-secondary-700 dark:text-secondary-300">
              The ForceField Scanner processes the following data when you run a scan:
            </p>
            <ul class="text-secondary-700 dark:text-secondary-300">
              <li><strong>Prompts submitted</strong> for analysis (attack prompts from the ForceField attack library)</li>
              <li><strong>Scanned URLs</strong> or endpoint identifiers you provide</li>
              <li><strong>Vulnerability results</strong> including risk scores, threat classifications, and recommendations</li>
              <li><strong>Logs and timestamps</strong> for rate-limiting and abuse prevention</li>
            </ul>

            <h2 class="mt-8 text-2xl font-bold text-secondary-900 dark:text-white">Data Retention</h2>
            <p class="text-secondary-700 dark:text-secondary-300">
              Data may be retained to improve security analysis and protect the service. Scan result details (scores, findings, recommendations) are stored in your browser session and are not retained on our servers beyond what is needed for service operation and abuse prevention.
            </p>

            <h2 class="mt-8 text-2xl font-bold text-secondary-900 dark:text-white">Per-Surface Data Handling</h2>
            <div class="not-prose mt-4 overflow-x-auto rounded-lg border border-secondary-200 dark:border-secondary-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-secondary-100 dark:bg-secondary-800">
                    <th class="px-4 py-3 text-left font-semibold text-secondary-900 dark:text-white">Product Surface</th>
                    <th class="px-4 py-3 text-left font-semibold text-secondary-900 dark:text-white">Data Handling</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-secondary-200 dark:divide-secondary-700">
                  <tr>
                    <td class="px-4 py-3 font-medium text-secondary-900 dark:text-white">ForceField Scanner</td>
                    <td class="px-4 py-3 text-secondary-700 dark:text-secondary-300">Attack prompts sent to Gateway for analysis. Metadata (URL, timestamps) may be retained.</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-medium text-secondary-900 dark:text-white">ForceField Simulator</td>
                    <td class="px-4 py-3 text-secondary-700 dark:text-secondary-300">Prompts analyzed in real time. Results returned to browser only.</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-medium text-secondary-900 dark:text-white">ForceField Demo Lab</td>
                    <td class="px-4 py-3 text-secondary-700 dark:text-secondary-300">All scenarios pre-seeded and run locally in browser. No network requests.</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-medium text-secondary-900 dark:text-white">ForceField Gateway</td>
                    <td class="px-4 py-3 text-secondary-700 dark:text-secondary-300">Request metadata and audit logs stored per your retention policy. PII redacted before storage.</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <h2 class="mt-8 text-2xl font-bold text-secondary-900 dark:text-white">Authentication Data</h2>
            <p class="text-secondary-700 dark:text-secondary-300">
              We use Firebase Authentication. Email and account data are stored securely and never shared with third parties beyond the service providers listed in the <a href="/en/privacy" class="text-primary-600 dark:text-primary-400 hover:underline">full Privacy Policy</a>.
            </p>

            <h2 class="mt-8 text-2xl font-bold text-secondary-900 dark:text-white">Contact</h2>
            <p class="text-secondary-700 dark:text-secondary-300">
              For questions about data handling, contact our Privacy and Data Protection Officer at <a href="mailto:privacy@datasciencetech.ca" class="text-primary-600 dark:text-primary-400 hover:underline">privacy@datasciencetech.ca</a>.
            </p>

            <p class="mt-8 text-secondary-500 dark:text-secondary-500 text-sm">
              &copy; 9558-6616 Qu&eacute;bec Inc.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
