---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import siteContent from '../../content/site.en.json';

const lang = 'en';
const pageTitle = `${siteContent.company} | ${siteContent.tagline}`;
---

<MainLayout
  title={pageTitle}
  description={siteContent.meta.description}
  lang={lang}
>
  <Header lang={lang} content={siteContent} />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden py-16 md:py-20 lg:py-28 bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900">
      <div class="absolute inset-0 opacity-5">
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px]" viewBox="0 0 200 200" fill="none">
          <path d="M100 10 L180 50 L180 110 C180 150 145 185 100 195 C55 185 20 150 20 110 L20 50 Z" stroke="currentColor" stroke-width="1" class="text-primary-400"/>
        </svg>
      </div>
      <div class="container-custom relative">
        <div class="mx-auto max-w-4xl text-center">
          <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary-400">Data Science Technologies</p>
          <h1 class="mb-6 text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-tight">
            Runtime Authority for Agentic AI
          </h1>
          <p class="mb-10 text-xl md:text-2xl text-secondary-300 max-w-3xl mx-auto">
            We build production-ready security, orchestration, and governance infrastructure for the next generation of AI systems.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://forcefield.datasciencetech.ca"
              class="btn-accent inline-flex items-center gap-2 text-lg px-8 py-4"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              Explore ForceField
            </a>
            <a
              href="https://forcefield.datasciencetech.ca/demo-lab"
              class="btn inline-flex items-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 text-lg px-8 py-4"
            >
              See it in action
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Funnel Steps: Demo Lab -> Scanner -> Gateway -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl text-center mb-12">
          <h2 class="mb-3 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white">{siteContent.funnel_steps.title}</h2>
          <p class="text-lg text-secondary-500 dark:text-secondary-400">{siteContent.funnel_steps.subtitle}</p>
        </div>
        <div class="grid gap-8 md:grid-cols-3 max-w-5xl mx-auto">
          {siteContent.funnel_steps.steps.map((step) => {
            const colorMap = { primary: 'primary', blue: 'blue', purple: 'purple' };
            const borderColor = step.color === 'primary' ? 'border-primary-400' : step.color === 'blue' ? 'border-blue-400' : 'border-purple-400';
            const numBg = step.color === 'primary' ? 'bg-primary-500' : step.color === 'blue' ? 'bg-blue-500' : 'bg-purple-500';
            return (
              <div class={`relative rounded-2xl border-2 ${borderColor} bg-white dark:bg-secondary-900 p-6 flex flex-col`}>
                <div class={`inline-flex items-center justify-center w-10 h-10 rounded-full ${numBg} text-white font-bold text-lg mb-4`}>{step.number}</div>
                <h3 class="text-xl font-bold text-secondary-900 dark:text-white mb-1">{step.name}</h3>
                <p class="text-sm font-semibold text-primary-600 dark:text-primary-400 mb-3">{step.hook}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-300 mb-6 flex-grow">{step.description}</p>
                <a
                  href={step.number === '1' ? 'https://forcefield.datasciencetech.ca/demo-lab' : step.number === '2' ? 'https://forcefield.datasciencetech.ca/scan/start' : 'https://forcefield.datasciencetech.ca'}
                  class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 dark:text-primary-400 hover:underline"
                >
                  {step.cta} &rarr;
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Our Product -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-4 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">ForceField</h2>
          <p class="mb-10 text-lg text-secondary-500 dark:text-secondary-400 text-center max-w-2xl mx-auto">
            AI Security Gateway for apps and agents. Protect every prompt, every response, every tool call.
          </p>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 max-w-5xl mx-auto">
            <a href="https://forcefield.datasciencetech.ca/python-sdk" class="group rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-secondary-50 dark:bg-secondary-900 p-6 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <h3 class="mb-2 text-lg font-bold text-secondary-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Python SDK</h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-300 mb-3">Open-source SDK. pip install forcefield. Apache 2.0.</p>
              <span class="text-sm font-semibold text-primary-600 dark:text-primary-400">Free &rarr;</span>
            </a>
            <a href="https://forcefield.datasciencetech.ca" class="group rounded-2xl border-2 border-primary-300 dark:border-primary-600 bg-primary-50 dark:bg-primary-900/20 p-6 hover:border-primary-400 dark:hover:border-primary-500 transition-colors">
              <h3 class="mb-2 text-lg font-bold text-secondary-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Gateway</h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-300 mb-3">Cloud-hosted 10-step security pipeline. Drop-in OpenAI proxy.</p>
              <span class="text-sm font-semibold text-primary-600 dark:text-primary-400">Free (limited time) &rarr;</span>
            </a>
            <a href="/en/vscode-extension" class="group rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-secondary-50 dark:bg-secondary-900 p-6 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <h3 class="mb-2 text-lg font-bold text-secondary-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">VS Code Extension</h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-300 mb-3">Sentinel Mode. Monitor AI agents in real-time. Protected paths.</p>
              <span class="text-sm font-semibold text-primary-600 dark:text-primary-400">Free &rarr;</span>
            </a>
            <a href="https://forcefield.datasciencetech.ca/enterprise-contact" class="group rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-secondary-50 dark:bg-secondary-900 p-6 hover:border-primary-300 dark:hover:border-primary-600 transition-colors">
              <h3 class="mb-2 text-lg font-bold text-secondary-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Enterprise</h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-300 mb-3">On-premise deployment. Dedicated instance. Custom security rules.</p>
              <span class="text-sm font-semibold text-primary-600 dark:text-primary-400">Contact Sales &rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Metrics Banner -->
    <section class="py-12 bg-gradient-to-r from-primary-600 to-primary-700 dark:from-primary-700 dark:to-primary-800">
      <div class="container-custom">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto text-center">
          {siteContent.metrics_banner.items.map((metric) => (
            <div>
              <p class="text-3xl md:text-4xl font-bold text-white mb-1">{metric.value}</p>
              <p class="text-sm text-primary-100 uppercase tracking-wide font-medium">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Secure at Runtime -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <h2 class="mb-12 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">{siteContent.secure_at_runtime.title}</h2>
        <div class="grid gap-8 md:grid-cols-3 max-w-5xl mx-auto">
          {siteContent.secure_at_runtime.pillars.map((pillar) => (
            <div class="rounded-2xl border border-secondary-200 dark:border-secondary-700 bg-secondary-50 dark:bg-secondary-900 p-6">
              <h3 class="text-lg font-bold text-secondary-900 dark:text-white mb-4">{pillar.name}</h3>
              <ul class="space-y-2">
                {pillar.items.map((item: string) => (
                  <li class="flex items-start gap-2 text-sm text-secondary-600 dark:text-secondary-300">
                    <svg class="mt-0.5 h-4 w-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Us -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <h2 class="mb-10 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
          {siteContent.why_us.title}
        </h2>
        <div class="mx-auto max-w-3xl space-y-4">
          {siteContent.why_us.items.map((item: string) => (
            <div class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-secondary-700 dark:text-secondary-300">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="border-y border-secondary-200 bg-white py-10 dark:border-secondary-700 dark:bg-secondary-800">
      <div class="container-custom">
        <p class="mb-6 text-center text-sm font-semibold uppercase tracking-wide text-secondary-600 dark:text-secondary-400">
          {siteContent.trust_bar.title}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-8 opacity-60 grayscale transition-all hover:opacity-100 hover:grayscale-0">
          {['GCP Cloud Run', 'Firebase Auth', 'Go', 'Python', 'Redis', 'Docker'].map((tech) => (
            <div class="text-secondary-600 dark:text-secondary-400 font-semibold text-lg">
              {tech}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom text-center">
        <h2 class="mb-4 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white">Get in touch</h2>
        <p class="mb-6 text-lg text-secondary-500 dark:text-secondary-400 max-w-xl mx-auto">
          Enterprise inquiries, partnerships, and general questions.
        </p>
        <a href="mailto:info@datasciencetech.ca" class="text-primary-600 dark:text-primary-400 font-semibold text-lg hover:underline">info@datasciencetech.ca</a>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://forcefield.datasciencetech.ca"
            class="btn-accent inline-flex items-center gap-2 px-6 py-3"
          >
            Explore ForceField
          </a>
          <a
            href="https://forcefield.datasciencetech.ca/enterprise-contact"
            class="btn inline-flex items-center gap-2 border-2 border-secondary-300 dark:border-secondary-600 text-secondary-700 dark:text-secondary-300 hover:bg-secondary-100 dark:hover:bg-secondary-700 px-6 py-3"
          >
            Enterprise Contact
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
