---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import siteContent from '../../content/site.en.json';
import benchContent from '../../content/benchmarks.en.json';

const lang = 'en';
const pageTitle = benchContent.meta.title;
const pageDescription = benchContent.meta.description;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Header lang={lang} content={siteContent} />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden py-16 md:py-20 lg:py-28 bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900">
      <div class="absolute inset-0 opacity-5">
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px]" viewBox="0 0 200 200" fill="none">
          <path d="M100 10 L180 50 L180 110 C180 150 145 185 100 195 C55 185 20 150 20 110 L20 50 Z" stroke="currentColor" stroke-width="1" class="text-primary-400"/>
        </svg>
      </div>
      <div class="container-custom relative">
        <div class="mx-auto max-w-4xl text-center">
          <h1 class="mb-6 text-4xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight">
            {benchContent.hero.title}
          </h1>
          <p class="mb-6 text-xl md:text-2xl text-secondary-300 max-w-3xl mx-auto">
            {benchContent.hero.subtitle}
          </p>
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <p class="text-lg text-secondary-600 dark:text-secondary-300 leading-relaxed text-center">
            {benchContent.intro}
          </p>
        </div>
      </div>
    </section>

    <!-- Core Detection Benchmarks -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-5xl">
          <h2 class="mb-2 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {benchContent.core.title}
          </h2>
          <p class="mb-10 text-center text-secondary-500 dark:text-secondary-400">{benchContent.core.subtitle}</p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
            {benchContent.core.items.map((item) => (
              <div class="text-center p-6 rounded-2xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <p class="text-3xl md:text-4xl font-bold text-primary-600 dark:text-primary-400 mb-2">{item.value}</p>
                <p class="font-semibold text-secondary-900 dark:text-white mb-1">{item.label}</p>
                <p class="text-sm text-secondary-500 dark:text-secondary-400">{item.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Agentic Security Benchmarks -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-5xl">
          <h2 class="mb-2 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {benchContent.agentic.title}
          </h2>
          <p class="mb-10 text-center text-secondary-500 dark:text-secondary-400">{benchContent.agentic.subtitle}</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {benchContent.agentic.items.map((item) => (
              <div class="text-center p-6 rounded-2xl bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800">
                <p class="text-3xl md:text-4xl font-bold text-primary-600 dark:text-primary-400 mb-2">{item.value}</p>
                <p class="font-semibold text-secondary-900 dark:text-white mb-1">{item.label}</p>
                <p class="text-sm text-secondary-500 dark:text-secondary-400">{item.detail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 6-Layer Detection Ensemble -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-10 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {benchContent.detection_layers.title}
          </h2>
          <div class="space-y-3">
            {benchContent.detection_layers.layers.map((layer, i) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-secondary-50 dark:bg-secondary-900 border border-secondary-100 dark:border-secondary-700">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary-600 text-white text-sm font-bold">
                  {i + 1}
                </span>
                <div>
                  <span class="font-semibold text-secondary-900 dark:text-white">{layer.name}</span>
                  <span class="text-secondary-500 dark:text-secondary-400 mx-2">&mdash;</span>
                  <span class="text-secondary-600 dark:text-secondary-300">{layer.detail}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Test Coverage -->
    <section class="section-padding bg-secondary-50 dark:bg-secondary-900">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-10 text-3xl md:text-4xl font-bold text-secondary-900 dark:text-white text-center">
            {benchContent.testing.title}
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {benchContent.testing.items.map((item) => (
              <div class="text-center p-5 rounded-2xl bg-white dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
                <p class="text-3xl font-bold text-primary-600 dark:text-primary-400 mb-1">{item.value}</p>
                <p class="text-sm text-secondary-600 dark:text-secondary-400">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- What We Don't Claim -->
    <section class="section-padding bg-white dark:bg-secondary-800">
      <div class="container-custom">
        <div class="mx-auto max-w-4xl">
          <h2 class="mb-8 text-2xl md:text-3xl font-bold text-secondary-900 dark:text-white text-center">
            {benchContent.caveats.title}
          </h2>
          <div class="rounded-2xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 p-8">
            <ul class="space-y-3">
              {benchContent.caveats.items.map((item: string) => (
                <li class="flex items-start gap-3 text-secondary-700 dark:text-secondary-300">
                  <svg class="mt-0.5 h-5 w-5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gradient-to-br from-primary-600 to-primary-700 dark:from-primary-700 dark:to-primary-800">
      <div class="container-custom text-center">
        <h2 class="mb-4 text-2xl md:text-3xl font-bold text-white">
          See these numbers live
        </h2>
        <p class="mb-8 text-lg text-primary-100 max-w-2xl mx-auto">
          Watch ForceField block attacks in the Demo Lab, then verify the benchmarks against your own workloads with a free scan.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://forcefield.datasciencetech.ca/demo-lab"
            class="btn inline-flex items-center gap-2 bg-white text-primary-700 hover:bg-primary-50 focus:ring-white text-lg px-8 py-4"
          >
            Try Demo Lab
          </a>
          <a
            href="https://forcefield.datasciencetech.ca/scan/start"
            class="btn inline-flex items-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 text-lg px-8 py-4"
          >
            Run Free Scan
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} content={siteContent} />
</MainLayout>
